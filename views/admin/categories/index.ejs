<h1>Admin - Categorías</h1>

<p>
  <a class="btn" href="/admin/categorias/new">+ Nueva categoría</a>
  <a class="btn" href="/admin/juegos/new">+ Nuevo juego</a>
</p>

<div class="table-wrap">
<table class="table">
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% categories.forEach(c => { %>
      <tr>
        <td><%= c.name %></td>
        <td>
          <a class="btn btn--small" href="/admin/categorias/<%= c.id %>/edit">Editar</a>
          <a class="btn btn--small btn--danger" href="/admin/categorias/<%= c.id %>/delete">Borrar</a>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
</div>
