<div class="auth-page">
  <div class="auth-card <%= (typeof error !== 'undefined' && error) ? 'auth-card--error' : '' %>">
    <div class="auth-header">
      <div class="auth-icon" aria-hidden="true">
        <%- include('../partials/icon', { name: 'user' }) %>
      </div>
      <div>
        <h1 class="auth-title">Login</h1>
        <p class="auth-subtitle">Accede para comprar y ver tu carrito.</p>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert--error" role="alert">
        <strong>Revisa el formulario:</strong> <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/login" class="auth-form" novalidate>
      <div class="field">
        <label for="identifier">Usuario o email</label>

        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <%- include('../partials/icon', { name: 'mail' }) %>
          </span>

          <input
            id="identifier"
            name="identifier"
            type="text"
            autocomplete="username"
            required
            class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.identifier) ? 'input--invalid' : '' %>"
            value="<%= (typeof values !== 'undefined' && values && values.identifier) ? values.identifier : '' %>"
          >
        </div>

        <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.identifier) { %>
          <p class="field-error"><%= fieldErrors.identifier %></p>
        <% } %>
      </div>

      <div class="field">
        <label for="password">Contraseña</label>

        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <%- include('../partials/icon', { name: 'lock' }) %>
          </span>

          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.password) ? 'input--invalid' : '' %>"
          >
        </div>

        <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.password) { %>
          <p class="field-error"><%= fieldErrors.password %></p>
        <% } %>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn">Entrar</button>
        <a href="/registro" class="btn-link">Crear cuenta</a>
        <a href="/" class="btn-link">Volver</a>
      </div>
    </form>
  </div>
</div>
