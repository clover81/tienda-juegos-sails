<div class="auth-page">
  <div class="auth-card <%= (typeof error !== 'undefined' && error) ? 'auth-card--error' : '' %>">
    <div class="auth-header">
      <div class="auth-icon" aria-hidden="true">
        <%- include('../partials/icon', { name: 'user-plus' }) %>
      </div>
      <div>
        <h1 class="auth-title">Registro</h1>
        <p class="auth-subtitle">Crea tu cuenta en menos de un minuto.</p>
      </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert--error" role="alert">
        <strong>Revisa el formulario:</strong> <%= error %>
      </div>
    <% } %>

    <form method="POST" action="/registro" class="auth-form" novalidate>
      <div class="field">
        <label for="username">Usuario</label>
        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <%- include('../partials/icon', { name: 'user' }) %>
          </span>
          <input
            id="username"
            name="username"
            type="text"
            autocomplete="username"
            required
            class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.username) ? 'input--invalid' : '' %>"
            value="<%= (typeof values !== 'undefined' && values && values.username) ? values.username : '' %>"
          >
        </div>
        <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.username) { %>
          <p class="field-error"><%= fieldErrors.username %></p>
        <% } %>
      </div>

      <div class="field">
        <label for="email">Email</label>
        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <%- include('../partials/icon', { name: 'mail' }) %>
          </span>
          <input
            id="email"
            name="email"
            type="email"
            autocomplete="email"
            required
            class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) ? 'input--invalid' : '' %>"
            value="<%= (typeof values !== 'undefined' && values && values.email) ? values.email : '' %>"
          >
        </div>
        <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.email) { %>
          <p class="field-error"><%= fieldErrors.email %></p>
        <% } %>
      </div>

      <div class="field">
        <label for="name">Nombre</label>
        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <%- include('../partials/icon', { name: 'user' }) %>
          </span>
          <input
            id="name"
            name="name"
            type="text"
            autocomplete="name"
            required
            class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.name) ? 'input--invalid' : '' %>"
            value="<%= (typeof values !== 'undefined' && values && values.name) ? values.name : '' %>"
          >
        </div>
        <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.name) { %>
          <p class="field-error"><%= fieldErrors.name %></p>
        <% } %>
      </div>

      <div class="field">
        <label for="password">Contraseña</label>
        <div class="input-wrap">
          <span class="input-icon" aria-hidden="true">
            <%- include('../partials/icon', { name: 'lock' }) %>
          </span>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="new-password"
            required
            class="<%= (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.password) ? 'input--invalid' : '' %>"
          >
        </div>
        <% if (typeof fieldErrors !== 'undefined' && fieldErrors && fieldErrors.password) { %>
          <p class="field-error"><%= fieldErrors.password %></p>
        <% } %>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn">Crear cuenta</button>
        <a href="/login" class="btn-link">Ya tengo cuenta</a>
        <a href="/" class="btn-link">Volver</a>
      </div>
    </form>
  </div>
</div>
