<div class="page">
  <h1>Categorías</h1>

  <div class="categories">
    <% categories.forEach(c => { %>
      <a href="/categoria/<%= c.id %>" class="category-pill">
        <%= c.name %>
      </a>
    <% }) %>
  </div>

  <div class="page-actions">
    <a href="/" class="btn btn--ghost">Volver</a>
  </div>
</div>
